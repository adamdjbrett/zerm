---
layout: layouts/base.njk
---
<article class="h-entry">
  <h1 class="p-name">{{ title }}</h1>
  <p>
    <time class="dt-published" datetime="{{ date | htmlDateString }}">{{ date | readableDate }}</time>
    by <span class="p-author h-card"><a class="p-name u-url" href="{{ metadata.url }}">{{ author or metadata.author }}</a></span>
  </p>

  {% if tags and tags.length %}
  <p>
    {% for tag in tags %}<a rel="tag" href="/tags/{{ tag | slugify }}/">#{{ tag }}</a>{% if not loop.last %} {% endif %}{% endfor %}
  </p>
  {% endif %}

  {% if page.url %}<a class="u-url" href="{{ page.url | absoluteUrl(metadata.url) }}" style="display:none">Permalink</a>{% endif %}

  <div class="e-content">{{ content | safe }}</div>

  {% set nav = collections.posts | postNav(page.url) %}
  <nav aria-label="Post navigation" class="pagination">
    {% if nav.newer %}<a class="button previous" href="{{ nav.newer.url }}">&larr; Newer</a>{% endif %}
    {% if nav.older %}<a class="button next" href="{{ nav.older.url }}">Older &rarr;</a>{% endif %}
  </nav>

  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      "headline": {{ title | dump | safe }},
      "description": {{ (description or metadata.description) | dump | safe }},
      "datePublished": {{ date | isoDate | dump | safe }},
      "dateModified": {{ date | isoDate | dump | safe }},
      "author": {"@type": "Person", "name": {{ (author or metadata.author) | dump | safe }}},
      "mainEntityOfPage": {"@type": "WebPage", "@id": {{ page.url | absoluteUrl(metadata.url) | dump | safe }}},
      "publisher": {"@type": "Organization", "name": {{ metadata.title | dump | safe }}}
    }
  </script>
</article>
