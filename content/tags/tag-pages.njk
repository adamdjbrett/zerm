---
layout: layouts/base.njk
pagination:
  data: collections.tagList
  size: 1
  alias: tag
permalink: "/tags/{{ tag | slugify }}/index.html"
published: true
---
{% set tagPosts = collections.posts | postsWithTag(tag) %}
<div class="post">
  <h1 class="post-title">
    tags ∋ #{{ tag }}
    ({{ tagPosts.length }} post{% if tagPosts.length != 1 %}s{% endif %})
  </h1>

  <ul>
    {% for post in tagPosts %}
    <li class="tag-list">
      {{ post.date | readableDate("yyyy.MM.dd") }}
      :: <a href="{{ post.url }}">{{ post.data.title }}</a>
      {% if post.data.tags and post.data.tags.length %}
      :: {% for itemTag in post.data.tags %}#<a href="/tags/{{ itemTag | slugify }}/">{{ itemTag }}</a>{% if not loop.last %} {% endif %}{% endfor %}
      {% endif %}
    </li>
    {% endfor %}
  </ul>
</div>
